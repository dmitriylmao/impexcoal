datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  news       News[]
  categories Category[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  news      News[]
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  imgUrl      String?
  publishedAt DateTime @default(now())

  project      Project           @relation(fields: [projectId], references: [id])
  projectId   String

  category     Category          @relation(fields: [categoryId], references: [id])
  categoryId  String
  translations NewsTranslation[]
}

model NewsTranslation {
  id      String @id @default(cuid())
  locale  String
  title   String
  content String

  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  newsId String

  @@unique([newsId, locale])
  @@index([locale])
}
